{
  "expo": {
    "name": "Smart Calorie Tracker",
    "slug": "smart-calorie-counter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo2.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo2.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kaduprasad.smartcalorietracker"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo2.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kaduprasad.smartcalorietracker",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "READ_PHONE_STATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#FF7B00"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Smart Calorie Tracker to use the microphone for voice food input.",
          "speechRecognitionPermission": "Allow Smart Calorie Tracker to use speech recognition for voice food input."
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "1524c359-6f19-453d-a6db-2c823ac50094"
      }
    }
  }
}
