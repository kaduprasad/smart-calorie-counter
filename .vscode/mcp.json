{
	"servers": {
		"github": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-github"
			],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github-token}"
			}
		}
	},
	"inputs": [
		{
			"id": "github-token",
			"type": "promptString",
			"description": "GitHub Personal Access Token",
			"password": true
		}
	]
}